@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 text-center">
        <div class="card p-5">
            <h1 class="display-5 fw-bold" style="color: #1a237e;">
                Industria Típica Guatemalteca S.A.
            </h1>
            <p class="lead text-muted mt-3">
                Sistema de gestión de facturas y pagos
            </p>
            <hr />
            <div class="row mt-4 g-3">
                <div class="col-md-6">
                    <a href="/Configuracion" class="btn btn-primary w-100 py-3">
                        Cargar Configuración
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/Transacciones" class="btn btn-primary w-100 py-3">
                        Cargar Transacciones
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/EstadoCuenta" class="btn btn-primary w-100 py-3">
                        Estado de Cuenta
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/Ingresos" class="btn btn-primary w-100 py-3">
                        Consultar Ingresos
                    </a>
                </div>
            </div>
            <div class="mt-4">
                <form method="post" asp-page-handler="Reset">
                    <button type="submit" class="btn btn-danger px-5"
                            onclick="return confirm('¿Seguro que deseas borrar todos los datos?')">
                        Resetear Datos
                    </button>
                </form>
                @if (Model.Mensaje != null)
                {
                    <div class="alert alert-success mt-3">@Model.Mensaje</div>
                }
            </div>
        </div>
    </div>
</div>